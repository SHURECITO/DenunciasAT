# ============================================================
# DenunciasAT — Variables de entorno
# Copiar a .env y completar todos los valores marcados con !!!
# NUNCA commitear el archivo .env real
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_HOST="xxx"
DB_PORT="xxx"
DB_USER="xxx"
DB_PASSWORD="xxx"
DB_NAME="xxx"

# DB_SYNC=true sincroniza el schema automáticamente (solo para desarrollo)
# En producción con datos reales: DB_SYNC=false y usar migraciones
DB_SYNC=true

# ── Autenticación ────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo 32 caracteres. NUNCA usar el valor de ejemplo.
JWT_SECRET=!!!GENERAR_CON_COMANDO_DE_ARRIBA!!!
JWT_EXPIRES_IN=8h

# ── Seed de datos iniciales ──────────────────────────────────
# SEED_ENABLED=true crea el usuario admin en el primer arranque
# Cambiar a false después del primer deploy
SEED_ENABLED=true
# Password inicial del admin para /auth/seed (mínimo 12 caracteres)
SEED_ADMIN_PASSWORD=!!!PASSWORD_SEGURO_MIN_12!!!

# Habilita Swagger en /api-docs
# En desarrollo (NODE_ENV != production): acceso libre si SWAGGER_ENABLED=true
# En producción: requiere SWAGGER_USER + SWAGGER_PASSWORD (Basic Auth)
#   Si faltan las credenciales en producción, Swagger queda deshabilitado aunque esté true.
SWAGGER_ENABLED=false
SWAGGER_USER=!!!USUARIO_SWAGGER!!!
SWAGGER_PASSWORD=!!!PASSWORD_SWAGGER_MIN_16!!!

# ── Puertos expuestos (host) ─────────────────────────────────
# Los contenedores usan puertos internos fijos (3000, 3001)
# Estos valores controlan qué puerto del HOST se expone
API_PORT=8741
FRONTEND_PORT=8742

# ── URL del frontend (para CORS en la API) ───────────────────
# En desarrollo: http://localhost:8742
# En producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:8742

# ── Google Cloud Storage (almacenamiento de archivos) ─────────
# GCS usa Application Default Credentials (ADC) + IAM Service Account Credentials API.
# No usar key.json ni GOOGLE_APPLICATION_CREDENTIALS en produccion.
# Buckets GCS (deben existir previamente en el proyecto GCP)
GCS_BUCKET_EVIDENCIAS=denunciasat-evidencias
GCS_BUCKET_DOCUMENTOS=denunciasat-documentos

# ── Evolution API (WhatsApp) ─────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
# CRÍTICO: debe tener formato UUID (xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx)
# Si no es UUID, Evolution API lo ignora y genera su propia clave aleatoria,
# rompiendo toda comunicación con dashboard-api y whatsapp-service.
# Generar con: node -e "const {randomUUID}=require('crypto');console.log(randomUUID())"
EVOLUTION_API_KEY=!!!GENERAR_UUID_CON_COMANDO_DE_ARRIBA!!!
EVOLUTION_INSTANCE_NAME=denunciasAt

# ── Servicios internos (Entrega 3 y 4) ──────────────────────
# Clave para comunicación interna chatbot-service → dashboard-api (sin JWT)
DASHBOARD_API_INTERNAL_KEY=!!!GENERAR_CLAVE_INTERNA!!!
# Claves segmentadas por servicio (recomendado en producción)
CHATBOT_API_INTERNAL_KEY=!!!CLAVE_INTERNA_CHATBOT!!!
DOCUMENT_API_INTERNAL_KEY=!!!CLAVE_INTERNA_DOCUMENT!!!
DASHBOARD_TO_DOCUMENT_KEY=!!!CLAVE_DASHBOARD_A_DOCUMENT!!!
WHATSAPP_TO_CHATBOT_KEY=!!!CLAVE_WHATSAPP_A_CHATBOT!!!
WHATSAPP_QR_INTERNAL_KEY=!!!CLAVE_DASHBOARD_A_WHATSAPP_QR!!!

# Firma HMAC opcional para webhooks de Evolution API (defensa en profundidad)
WHATSAPP_WEBHOOK_HMAC_SECRET=

# Lista de hosts permitidos para descargar media remota antes de subir a GCS
# Separar por comas, ejemplo: evolution-api,media.tu-dominio.com
ALLOWED_REMOTE_MEDIA_HOSTS=evolution-api

# URL interna del document-service (solo relevante dentro de la red Docker)
DOCUMENT_SERVICE_URL=http://document-service:3004
# API Key de Google Gemini para clasificación de denuncias (gemini-2.0-flash-lite)
GEMINI_API_KEY=!!!OBTENER_EN_AI_STUDIO!!!
# Número de WhatsApp del administrador para alertas internas (formato internacional sin +)
ADMIN_WHATSAPP_NUMBER=57300000000

# ── Monitoreo ────────────────────────────────────────────────
# Bot de Telegram para alertas del sistema (backup.sh, healthcheck.sh)
TELEGRAM_BOT_TOKEN=!!!OBTENER_DE_BOTFATHER!!!
TELEGRAM_CHAT_ID=!!!CHAT_ID_DEL_BOT!!!

# ── GCP — Despliegue en producción ───────────────────────────
# ID del proyecto GCP donde se despliega el sistema
GCP_PROJECT_ID=!!!ID_PROYECTO_GCP!!!
# Región donde vive el Artifact Registry y la VM
GCP_REGION=us-central1
# Tag de imagen para docker-compose.prod.yml (lo sobrescribe el CI/CD con el SHA)
IMAGE_TAG=latest
# URL pública del frontend (para CORS y verificación post-deploy)
# Ejemplo: https://denuncias.tudominio.com
# URL pública del API (WebSocket y conexiones del navegador): ej. http://IP_PUBLICA:8741
NEXT_PUBLIC_WS_URL=!!!URL_PUBLICA_API!!!
# Misma URL que NEXT_PUBLIC_WS_URL — usada como fallback en lib/socket.ts
NEXT_PUBLIC_API_URL=!!!URL_PUBLICA_API!!!
